{
  "name": "mendlink-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "migrate-firebase": "node scripts/migrate-firebase-admin.js",
    "migrate-production": "node scripts/migrate-firebase-prod.js",
    "restore-firestore-rules": "cp firestore.rules.backup firestore.rules && firebase deploy --only firestore:rules",
    "build": "tsc",
    "build:development": "eas build --platform android --profile development --local",
    "build:preview": "eas build --platform all --profile preview",
    "build:production": "eas build --platform all --profile production",
    "export": "expo export",
    "export:web": "expo export --platform web",
    "render-build": "npm install && npm run export:web",
    "deploy:render": "./scripts/deploy-render.sh",
    "firebase-emulators": "firebase emulators:start",
    "firebase-deploy": "firebase deploy"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "~2.2.0",
    "@react-navigation/bottom-tabs": "^7.8.4",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/stack": "^7.4.8",
    "expo": "^54.0.25",
    "expo-constants": "^18.0.10",
    "expo-dev-client": "~6.0.18",
    "expo-font": "~14.0.8",
    "expo-localization": "~17.0.7",
    "expo-location": "~19.0.7",
    "expo-status-bar": "~3.0.8",
    "express": "^5.1.0",
    "firebase": "^12.3.0",
    "firebase-admin": "^13.6.0",
    "i18n-js": "^4.5.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "~13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.10",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
