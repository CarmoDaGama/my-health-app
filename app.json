{
  "expo": {
    "name": "MENDLINK",
    "slug": "health-locator-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E7D32"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "MENDLINK needs location access to find nearby healthcare services and assist with professional and institution registration.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "MENDLINK needs location access to find nearby healthcare services and provide real-time navigation.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.carmodagama.mendlink"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2E7D32"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.carmodagama.mendlink"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to find nearby healthcare services and provide navigation.",
          "locationWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to find nearby healthcare services.",
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      "expo-localization",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "7ed61a68-9c1b-4c51-b190-dd383bc50f9a"
      }
    },
    "owner": "carmodagama"
  }
}
