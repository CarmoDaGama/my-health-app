rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================
    // IMPLEMENTAÇÃO CLIENT-SIDE
    // ========================================
    // Estas regras suportam implementação client-side como alternativa
    // aos Cloud Functions. Para produção, recomenda-se usar Cloud Functions
    // para maior segurança e funcionalidades como envio de emails.
    //
    // NOTA: Custom Claims (isAdmin, role) devem ser definidos manualmente
    // via Firebase Console ou scripts de admin, pois apenas Cloud Functions
    // podem definir Custom Claims automaticamente.
    // ========================================
    
    // ========================================
    // FUNÇÕES AUXILIARES PARA ADMIN
    // ========================================
    
    // Verificar se usuário é admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.isAdmin == true;
    }
    
    // Verificar se usuário tem role específica
    function hasRole(role) {
      return request.auth != null && 
             request.auth.token.role == role;
    }
    
    // Verificar se é super admin
    function isSuperAdmin() {
      return hasRole('super_admin');
    }
    
    // Verificar se é moderador
    function isModerator() {
      return hasRole('moderator') || isSuperAdmin();
    }
    
    // Verificar se tem acesso a analytics
    function hasAnalyticsAccess() {
      return hasRole('analytics_viewer') || isAdmin();
    }
    
    // ========================================
    // COLEÇÃO: users
    // ========================================
    match /users/{userId} {
      // Users podem ler e escrever seus próprios dados
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Permitir criação durante registro
      allow create: if request.auth != null;
      // Admins podem ler todos os usuários
      allow read: if isAdmin();
      // Admins podem atualizar usuários (para verificação, etc)
      allow update: if isAdmin();
    }
    
    // ========================================
    // COLEÇÃO: healthServices (serviços aprovados)
    // ========================================
    match /healthServices/{serviceId} {
      // ✅ LEITURA PÚBLICA TOTALMENTE LIBERADA
      // Qualquer pessoa pode ler serviços de saúde (dados públicos)
      allow read: if true;
      
      // Usuários autenticados podem criar serviços (sujeito a aprovação)
      allow create: if request.auth != null;
      // Criadores podem atualizar seus próprios serviços, ou admins
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.createdBy || isAdmin());
      // Apenas admins podem deletar
      allow delete: if isAdmin();
    }
    
    // ========================================
    // COLEÇÃO: registeredServices (aguardando aprovação)
    // ========================================
    match /registeredServices/{serviceId} {
      // ✅ LEITURA PÚBLICA LIBERADA PARA SERVIÇOS APROVADOS
      // Qualquer um pode ler serviços aprovados (dados públicos)
      allow read: if true;
      
      // Admins podem ler todos os registros pendentes
      allow read: if isAdmin();
      // Criadores podem ler seus próprios registros
      allow read: if request.auth != null && 
        request.auth.uid == resource.data.createdBy;
      
      // Qualquer usuário autenticado pode criar (submeter para aprovação)
      // Deve incluir campos obrigatórios
      allow create: if request.auth != null &&
        request.resource.data.keys().hasAll(['name', 'createdBy', 'createdAt', 'status']) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.createdBy == request.auth.uid;
      
      // Apenas criador pode atualizar (se ainda pendente)
      allow update: if request.auth != null && 
        request.auth.uid == resource.data.createdBy &&
        resource.data.status == 'pending';
      
      // Admins podem atualizar status (aprovar/rejeitar)
      allow update: if isAdmin();
      
      // Apenas admin pode deletar
      allow delete: if isAdmin();
    }
    
    // ========================================
    // COLEÇÃO: adminRoles (roles administrativas)
    // ========================================
    match /adminRoles/{userId} {
      // Admins podem ler suas próprias roles
      allow read: if request.auth != null && request.auth.uid == userId;
      // Super admins e admins podem ler todas as roles
      allow read: if isAdmin();
      
      // Apenas super admins podem criar novas roles
      allow create: if isSuperAdmin() &&
        request.resource.data.keys().hasAll(['userId', 'role', 'isAdmin', 'createdAt', 'assignedBy']) &&
        request.resource.data.assignedBy == request.auth.uid &&
        request.resource.data.isAdmin == true;
      
      // Apenas super admins podem atualizar roles
      allow update: if isSuperAdmin();
      
      // Apenas super admins podem deletar roles
      allow delete: if isSuperAdmin();
    }
    
    // ========================================
    // COLEÇÃO: adminLogs (logs de ações administrativas)
    // ========================================
    match /adminLogs/{logId} {
      // Apenas admins podem ler logs
      allow read: if isAdmin();
      // Admins podem criar logs (para implementação client-side)
      allow create: if isAdmin() && 
        request.resource.data.keys().hasAll(['adminId', 'adminEmail', 'action', 'timestamp']) &&
        request.resource.data.adminId == request.auth.uid;
      // Logs não podem ser atualizados ou deletados
      allow update, delete: if false;
    }
    
    // Rules for favorites collection
    match /favorites/{userId} {
      // Users can only access their own favorites
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // ========================================
    // COLEÇÃO: institutionServices (serviços gerenciados por instituições)
    // ========================================
    match /institutionServices/{serviceId} {
      // Instituições podem ler seus próprios serviços
      allow read: if request.auth != null && 
        request.auth.uid == resource.data.institutionId;
      
      // Instituições podem criar serviços para si mesmas
      allow create: if request.auth != null && 
        request.resource.data.institutionId == request.auth.uid &&
        validateInstitutionServiceData(request.resource.data);
      
      // Instituições podem atualizar seus próprios serviços
      allow update: if request.auth != null && 
        request.auth.uid == resource.data.institutionId;
      
      // Instituições podem deletar seus próprios serviços
      allow delete: if request.auth != null && 
        request.auth.uid == resource.data.institutionId;
        
      // Admins podem ler, criar, atualizar e deletar qualquer serviço
      allow read, write: if isAdmin();
    }
    
    // Função para validar dados de serviços de instituição
    function validateInstitutionServiceData(data) {
      return data.keys().hasAll(['name', 'description', 'category', 'institutionId', 'createdAt'])
        && data.name is string
        && data.name.size() > 0
        && data.description is string 
        && data.description.size() > 0
        && data.institutionId is string
        && data.institutionId.size() > 0;
    }

    // ========================================
    // COLEÇÃO: reviews (avaliações de serviços)
    // ========================================
    match /reviews/{reviewId} {
      // Qualquer um pode ler reviews públicas
      allow read: if true;
      
      // Usuários autenticados podem criar reviews
      allow create: if request.auth != null && 
        validateReviewData(request.resource.data);
      
      // Criadores podem atualizar suas reviews, ou moderadores
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.userId || isModerator());
      
      // Criadores podem deletar suas reviews, ou moderadores
      allow delete: if request.auth != null && 
        (request.auth.uid == resource.data.userId || isModerator());
    }
    
    // ========================================
    // COLEÇÃO: reportedReviews (reviews reportadas)
    // ========================================
    match /reportedReviews/{reportId} {
      // Apenas moderadores podem ler
      allow read: if isModerator();
      // Usuários podem criar reports
      allow create: if request.auth != null;
      // Apenas moderadores podem atualizar/deletar
      allow update, delete: if isModerator();
    }
    
    // Helper functions for review validation
    function validateReviewData(data) {
      return data.keys().hasAll(['serviceId', 'userId', 'userName', 'rating', 'comment', 'createdAt', 'updatedAt', 'verified', 'helpful'])
        && data.rating is int
        && data.rating >= 1 
        && data.rating <= 5
        && data.comment is string
        && data.comment.size() >= 1  // Reduzido para permitir comentários mais curtos
        && data.comment.size() <= 1000
        && data.serviceId is string
        && data.serviceId.size() > 0
        && data.userName is string
        && data.userName.size() > 0
        && data.userId is string
        && data.userId.size() > 0
        && data.verified == false // New reviews start as unverified
        && data.helpful is int
        && data.helpful >= 0
        && (!data.keys().hasAny(['reported']) || data.reported is bool) // reported is optional
        && (!data.keys().hasAny(['userAvatar']) || data.userAvatar is string || data.userAvatar == null); // userAvatar is optional
    }
    
    function validateReviewUpdate(data) {
      return data.diff(resource.data).affectedKeys().hasOnly(['rating', 'comment', 'updatedAt', 'helpful'])
        && (!data.diff(resource.data).affectedKeys().hasAny(['rating']) || 
            (data.rating is int && data.rating >= 1 && data.rating <= 5))
        && (!data.diff(resource.data).affectedKeys().hasAny(['comment']) || 
            (data.comment is string && data.comment.size() >= 1 && data.comment.size() <= 1000));
    }
  }
}
