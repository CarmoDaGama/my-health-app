rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for users collection - TEMPORARIAMENTE MAIS PERMISSIVO PARA DEBUG
    match /users/{userId} {
      // Users can read and write their own data
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Allow creation during registration
      allow create: if request.auth != null;
      // Also allow reading user data when authenticated (for debugging)
      allow read: if request.auth != null;
    }
    
    // Rules for healthServices collection
    match /healthServices/{serviceId} {
      // Anyone can read health services (public data)
      allow read: if true;
      // Only authenticated users can create services
      allow create: if request.auth != null;
      // Only the creator or admin can update/delete
      allow update, delete: if request.auth != null && 
        (request.auth.uid == resource.data.createdBy || 
         request.auth.token.admin == true);
    }
    
    // Rules for registeredServices collection (pending approval)
    match /registeredServices/{serviceId} {
      // Only authenticated users can read
      allow read: if request.auth != null;
      // Any authenticated user can create (submit for approval)
      allow create: if request.auth != null;
      // Only creator or admin can update
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.createdBy || 
         request.auth.token.admin == true);
      // Only admin can delete
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Rules for favorites collection
    match /favorites/{userId} {
      // Users can only access their own favorites
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Rules for reviews collection - TEMPORARIAMENTE MAIS PERMISSIVO PARA DEBUG
    match /reviews/{reviewId} {
      // Anyone can read reviews (public data)
      allow read: if true;
      
      // Allow any authenticated user to create reviews (simplified for debugging)
      allow create: if request.auth != null;
      
      // Allow any authenticated user to update reviews (simplified for debugging)  
      allow update: if request.auth != null;
      
      // Allow any authenticated user to delete reviews (simplified for debugging)
      allow delete: if request.auth != null;
    }
    
    // Helper functions for review validation
    function validateReviewData(data) {
      return data.keys().hasAll(['serviceId', 'userId', 'userName', 'rating', 'comment', 'createdAt', 'updatedAt', 'verified'])
        && data.rating is int
        && data.rating >= 1 
        && data.rating <= 5
        && data.comment is string
        && data.comment.size() >= 5  // Reduzido de 10 para 5
        && data.comment.size() <= 1000  // Aumentado de 500 para 1000
        && data.serviceId is string
        && data.serviceId.size() > 0
        && data.userName is string
        && data.userName.size() > 0
        && data.verified == false; // New reviews start as unverified
    }
    
    function validateReviewUpdate(data) {
      return data.diff(resource.data).affectedKeys().hasOnly(['rating', 'comment', 'updatedAt', 'helpful'])
        && (!data.diff(resource.data).affectedKeys().hasAny(['rating']) || 
            (data.rating is int && data.rating >= 1 && data.rating <= 5))
        && (!data.diff(resource.data).affectedKeys().hasAny(['comment']) || 
            (data.comment is string && data.comment.size() >= 5 && data.comment.size() <= 1000));
    }
  }
}
